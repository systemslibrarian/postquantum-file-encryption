{
  "metadata": [
    {
      "src": [
        {
          "files": [ "src/PostQuantum.FileEncryption/PostQuantum.FileEncryption.csproj" ],
          "src": ".."
        }
      ],
      "dest": "api",
      "properties": { "TargetFramework": "net10.0", "Configuration": "Release" }
    }
  ],
  "build": {
    "content": [
      { "files": [ "api/**.yml", "api/index.md" ] },
      { "files": [ "index.md", "toc.yml" ] }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "PostQuantum.FileEncryption",
      "_appTitle": "PostQuantum.FileEncryption API",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
