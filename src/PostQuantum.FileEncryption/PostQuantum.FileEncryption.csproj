<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PostQuantum.FileEncryption</RootNamespace>
    <AssemblyName>PostQuantum.FileEncryption</AssemblyName>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Trim- and AOT-compatible: enables the trimming/AOT analyzers so we keep it that way. -->
    <IsAotCompatible>true</IsAotCompatible>
    <!-- The library implements the experimental ML-KEM feature internally, so it opts in to its
         own PQFE001 ([Experimental]) and PQFE002 ([Obsolete], 1.0.0-rc.2 deprecation pointing to
         PostQuantum.FileEncryption.Hybrid) diagnostics. Both attributes still flow to external
         consumers, who see PQFE001/PQFE002 in their IDE and build output. -->
    <NoWarn>$(NoWarn);PQFE001;PQFE002</NoWarn>
  </PropertyGroup>

  <!-- NuGet package metadata -->
  <PropertyGroup>
    <PackageId>PostQuantum.FileEncryption</PackageId>
    <Version>1.1.0</Version>
    <FileVersion>1.1.0.0</FileVersion>
    <InformationalVersion>1.1.0</InformationalVersion>
    <MinClientVersion>6.0.0</MinClientVersion>
    <Title>PostQuantum.FileEncryption</Title>
    <Description>Production-ready, fail-closed file and stream encryption for .NET 10. Authenticated AES-256-GCM containers with chunked streaming and progress, PBKDF2-HMAC-SHA256 or Argon2id key derivation, atomic file output, zeroable passphrases, and a non-sensitive EventSource for SIEM/OpenTelemetry. The IContentKeyProvider envelope-key seam wraps content keys with an external KMS/HSM so the master key never enters your process. AES-256 keeps data confidential against a harvest-now-decrypt-later quantum adversary. The .pqfe v2 container format is FROZEN for the 1.x line — pinned by published cross-implementation test vectors against a Rust/WASM reference. Production post-quantum public-key encryption ships as the companion package PostQuantum.FileEncryption.Hybrid (X25519 + ML-KEM-768 combiner with multi-recipient support). AOT-compatible; deterministic builds; SourceLink; CycloneDX SBOM and SLSA-style build-provenance attestation on every release; public API surface locked by Microsoft.CodeAnalysis.PublicApiAnalyzers.</Description>
    <PackageReleaseNotes>1.1.0 — the package family grows: pqfe ships as the installable dotnet tool PostQuantum.FileEncryption.Tool, and PostQuantum.FileEncryption.Extensions.DependencyInjection adds AddPqFileEncryption()/AddPqHybridFileEncryption() for Microsoft.Extensions.DependencyInjection hosts, both versioned in lockstep. Live Rust↔.NET cross-implementation interop CI now round-trips fresh payloads in both directions on every push. Fixes: decryption progress reports the exact plaintext total (Fraction now reaches 1.0); key-material hygiene hardening — the content key is zeroed even when header construction fails, and LocalKekContentKeyProvider.Generate() zeroes its intermediate KEK copy. No format change: the .pqfe v2 container format remains FROZEN for the 1.x line. See CHANGELOG.md.</PackageReleaseNotes>
    <PackageTags>encryption;file-encryption;stream-encryption;aes-gcm;aes-256;argon2id;pbkdf2;passphrase;authenticated-encryption;aead;cryptography;security;streaming;post-quantum;pqc;ml-kem;harvest-now-decrypt-later;envelope-encryption;kms;hsm;dotnet;net10;aot</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageProjectUrl>https://github.com/systemslibrarian/postquantum-file-encryption</PackageProjectUrl>
    <RepositoryUrl>https://github.com/systemslibrarian/postquantum-file-encryption</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
  </PropertyGroup>

  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)../../README.md" Pack="true" PackagePath="\" />
    <None Include="$(MSBuildThisFileDirectory)../../LICENSE" Pack="true" PackagePath="\" />
    <None Include="$(MSBuildThisFileDirectory)../../assets/icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" Version="1.3.1" />
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" Version="3.11.0-beta1.24454.1" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PostQuantum.FileEncryption.Tests" />
    <InternalsVisibleTo Include="PostQuantum.FileEncryption.Hybrid" />
  </ItemGroup>

</Project>
